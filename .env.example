# ============================================================================
# Environment configuration template — copy to `.env` and adjust.
# All API clients fall back to deterministic MOCK data when keys are absent
# or the network is unavailable, so the project runs fully offline by default.
# ============================================================================

# Force-disable any real network calls (recommended for CI / reproducibility).
BMW_OFFLINE_MODE=false

# World Bank API is keyless & public — no token needed.
WORLDBANK_BASE_URL=https://api.worldbank.org/v2

# Open exchange / FX provider (optional; mock used if empty).
FX_API_KEY=
FX_BASE_URL=https://api.exchangerate.host

# HTTP behaviour
BMW_HTTP_TIMEOUT=8
BMW_HTTP_MAX_RETRIES=3
BMW_CACHE_DIR=.cache/api
